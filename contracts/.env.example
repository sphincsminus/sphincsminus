# Mainnet RPC for forge script broadcasting
RPC_URL=https://rpc.ankr.com/eth/<key>

# Deployer key (only needs gas; addresses below decide who controls the protocol)
DEPLOYER_PRIVATE_KEY=0x...

# Address allowed to call MintGate.postRoot() (the backend signer)
SIGNER=0x...

# Address that receives every 0.0025 ETH mint fee. KEEP THIS COLD.
DEV=0xCf28f6e251CFC47aAd38a6D63B40444C5f3fd3F7

# Address that receives the 10,000,000 SPHINCS LP reserve at deploy
LP_RECIPIENT=0x...

# Address that receives the 1,000,000 SPHINCS team reserve at deploy
TEAM_RECIPIENT=0x...

# Etherscan API key for verify
ETHERSCAN_API_KEY=
