# Upstash Redis (KV)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Mainnet RPC + signer key (the address that posts Merkle roots on-chain)
RPC_URL=https://rpc.ankr.com/eth/<key>
SIGNER_PRIVATE_KEY=0x...

# Deployed MintGate contract address
MINTGATE_ADDRESS=0x...

# Cron secret (Vercel needs an Authorization header)
CRON_SECRET=some-long-random-string

# Public verifier endpoint (the python verifier; can be a separate Vercel project,
# a Cloudflare worker with python-via-WASM, or your VPS).
# We embed the verifier in this same project via a child_process call to python3
# during local dev, but Vercel serverless does NOT have python by default.
# Two options:
#   1) ship a JS port of the verifier (sphincs_minus.js -- not yet written)
#   2) host the python verifier elsewhere and set VERIFIER_URL here
VERIFIER_URL=https://verifier.sphx.lol/verify
